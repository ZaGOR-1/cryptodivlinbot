# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional defaults (shown with their built-in values)

# How many top coins by market cap to track.
TOP_N_COINS=10

# Minimum percent move (in either direction) over the spike window
# that triggers an instant alert.
SPIKE_THRESHOLD_PCT=5.0

# Window over which the spike percent move is measured, in minutes.
SPIKE_WINDOW_MIN=5

# How often the bot polls market data, in seconds.
POLL_INTERVAL_SEC=60

# How often the periodic digest is dispatched, in minutes.
DIGEST_INTERVAL_MIN=5

# Per-coin / per-chat cooldown after a spike alert, in minutes.
ALERT_COOLDOWN_MIN=15

# Default UI language for new chats: en, uk, or ru.
DEFAULT_LANGUAGE=uk

# Path to the SQLite database file.
DB_PATH=cryptodivlinbot.sqlite

# Optional CoinGecko Pro API key (enables higher rate limits).
COINGECKO_API_KEY=

# Optional override for the CoinGecko base URL (e.g. for self-hosted proxies).
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Optional override for the Binance public API base URL.
BINANCE_BASE_URL=https://api.binance.com

# HTTP request timeout in seconds.
HTTP_TIMEOUT_SEC=10

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
